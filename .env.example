

PUBLIC_URL="...."


# Twilio Credentials & Numbers
TWILIO_ACCOUNT_SID=..
TWILIO_AUTH_TOKEN=..
TWILIO_US_NUMBER=+..
MY_INDIAN_NUMBER=+..        # comma-separated for multiple: +91...,+91...,+1...

# Active telephony channel — switches the whole stack: twilio | vobiz (default twilio).
TELEPHONY=twilio

# --- Vobiz (Indian telephony, inbound + outbound) ---
# Point your Vobiz number / SIP trunk answer URL at  https://PUBLIC_URL/incoming-call
# PUBLIC_URL is the bare host (no scheme), e.g. cranial-iciness-jinx.ngrok-free.dev
VOBIZ_AUTH_ID=..
VOBIZ_AUTH_TOKEN=..
# Caller-ID for outbound Vobiz calls (your Vobiz number).
VOBIZ_PHONE_NUMBER=+91797144244
# Wire format advertised in the Stream XML + passed to the serializer (re-negotiated
# from Vobiz's start event at runtime). Encoding: audio/x-mulaw | audio/x-l16. Rate: 8000 | 16000.
VOBIZ_ENCODING=audio/x-mulaw
VOBIZ_SAMPLE_RATE=8000
# L16 byte order: "be" per spec; flip to "le" if x-l16 frames arrive but STT is silent.
VOBIZ_L16_ENDIAN=be

# Soniox STT
SONIOX_API_KEY=..

# Cartesia TTS
CARTESIA_API_KEY=..
CARTESIA_VOICE_ID=..  # Bavani voice ID from cartesia.ai/voices

# Server Settings
PORT=8080
MAX_CALL_MINUTES=3

# LLM selection: openai | deepseek | sarvam | gemini | groq | huggingface | ai_gateway (default)
LLM_PROVIDER=deepseek

# Cap LLM context to system msg + last N messages (bounds prefill/TTFT on long calls).
LLM_MAX_HISTORY=16

# Request hedging (all network LLM providers): fire N parallel requests per turn,
# stream the fastest first-token, cancel the rest. Cuts tail latency from a single
# slow network path mid-call. 2 = hedged, 1 = disabled (single request). Costs ~Nx
# requests, but losers are killed at first byte so extra tokens are minimal.
LLM_HEDGE=2

# Warm STT/TTS/LLM with one dummy round-trip at server startup so the first real
# call doesn't pay provider cold-start. Default on; set to 0 to disable.
WARMUP=1

# Set to 1 to log per-leg TTFB (stt/llm/tts) each turn — find the slow leg. Off in prod.
DEBUG_TTFB=

# Silence (secs) after user speech before the turn ends. Lower = snappier, risks
# cutting users mid-pause. Default 0.3; raise to 0.4 if it clips users.
TURN_SILENCE_SECS=0.3

# OpenAI (direct inference — low TTFT, no gateway hop). Paste your key here.
# Default gpt-5.1-chat-latest: best TTFT + Telugu quality, non-reasoning (benchmark pick).
OPENAI_API_KEY=..
OPENAI_MODEL=gpt-5.1-chat-latest

# DeepSeek (cheaper, same Telugu quality). thinking auto-disabled in code for speed.
DEEPSEEK_API_KEY=..
DEEPSEEK_MODEL=deepseek-v4-flash

# Sarvam (most native Telugu, slower).
SARVAM_API_KEY=..
SARVAM_MODEL=sarvam-105b

# Gemini. flash-lite = lowest TTFT (default, dominant latency leg); flash = best quality.
GEMINI_API_KEY=..
GEMINI_MODEL=gemini-2.5-flash-lite

# Anthropic (direct — Claude Haiku 4.5 for the LLM, no gateway hop)
ANTHROPIC_API_KEY=..

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres