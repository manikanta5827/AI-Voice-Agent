

PUBLIC_URL="...."


# Twilio Credentials & Numbers
TWILIO_ACCOUNT_SID=..
TWILIO_AUTH_TOKEN=..
TWILIO_US_NUMBER=+..
MY_INDIAN_NUMBER=+..

# Soniox STT
SONIOX_API_KEY=..

# Cartesia TTS
CARTESIA_API_KEY=..
CARTESIA_VOICE_ID=..  # Bavani voice ID from cartesia.ai/voices

# Server Settings
PORT=8080
MAX_CALL_MINUTES=3

# LLM selection: openai | deepseek | sarvam | gemini | groq | huggingface | ai_gateway (default)
LLM_PROVIDER=deepseek

# Cap LLM context to system msg + last N messages (bounds prefill/TTFT on long calls).
LLM_MAX_HISTORY=16

# Set to 1 to log per-leg TTFB (stt/llm/tts) each turn — find the slow leg. Off in prod.
DEBUG_TTFB=

# Silence (secs) after user speech before the turn ends. Lower = snappier, risks
# cutting users mid-pause. Default 0.4; try 0.3 while latency-testing.
TURN_SILENCE_SECS=0.4

# OpenAI (direct inference — low TTFT, no gateway hop). Paste your key here.
# Default gpt-5.1-chat-latest: best TTFT + Telugu quality, non-reasoning (benchmark pick).
OPENAI_API_KEY=..
OPENAI_MODEL=gpt-5.1-chat-latest

# DeepSeek (cheaper, same Telugu quality). thinking auto-disabled in code for speed.
DEEPSEEK_API_KEY=..
DEEPSEEK_MODEL=deepseek-v4-flash

# Sarvam (most native Telugu, slower).
SARVAM_API_KEY=..
SARVAM_MODEL=sarvam-105b

# Gemini. flash = best quality; flash-lite = lower TTFT (try it to cut LLM latency).
GEMINI_API_KEY=..
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (direct — Claude Haiku 4.5 for the LLM, no gateway hop)
ANTHROPIC_API_KEY=..

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres