

PUBLIC_URL="...."


# Twilio Credentials & Numbers
TWILIO_ACCOUNT_SID=..
TWILIO_AUTH_TOKEN=..
TWILIO_US_NUMBER=+..
MY_INDIAN_NUMBER=+..

# Soniox STT
SONIOX_API_KEY=..

# Cartesia TTS
CARTESIA_API_KEY=..
CARTESIA_VOICE_ID=..  # Bavani voice ID from cartesia.ai/voices

# Server Settings
PORT=8080
MAX_CALL_MINUTES=3

# OpenAI API key (used by Pipecat's OpenAILLMService)
# For Vercel AI Gateway instead, set base_url in bot.py and use AI_GATEWAY_API_KEY here
OPENAI_API_KEY=..

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres